@model LoginViewModel

@{
    ViewData["Title"] = "Login";
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Login</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
</head>
<body>

<div class="container-fluid vh-100 d-flex align-items-center justify-content-center"
     style="background: linear-gradient(135deg, #667eea, #764ba2);">

    <div class="card border-0 shadow-lg" style="width:900px;">
        <div class="row g-0">

            <!-- Left Panel -->
            <div class="col-md-6 bg-white p-5">

                <div class="text-center mb-5">
                    <i class="bi bi-lightning-charge-fill fs-1 text-primary"></i>
                    <h4 class="fw-bold mt-2">Route Fitness</h4>
                    <small class="text-muted">Gym Management System</small>
                </div>

                <h3 class="text-center fw-bold">Admin Login</h3>
                <p class="text-center text-muted mb-4">
                    Welcome Back! Please login to your account
                </p>

                <form asp-action="Login" method="post">

                    <div asp-validation-summary="ModelOnly"
                         class="text-danger mb-3">
                    </div>

                    <div class="mb-3">
                        <input asp-for="Email"
                               class="form-control"
                               placeholder="Email Address" />
                        <span asp-validation-for="Email"
                              class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <input asp-for="Password"
                               class="form-control"
                               placeholder="Password" />
                        <span asp-validation-for="Password"
                              class="text-danger"></span>
                    </div>

                    <div class="form-check mb-4">
                        <input asp-for="RemeberMe"
                               class="form-check-input" />

                        <label asp-for="RemeberMe"
                               class="form-check-label">
                            Remember me for 24 hours
                        </label>
                    </div>

                    <button type="submit"
                            class="btn btn-primary w-100">
                        <i class="bi bi-box-arrow-in-right me-2"></i>
                        LOGIN TO DASHBOARD
                    </button>

                </form>

            </div>

            <!-- Right Panel -->
            <div class="col-md-6 text-white p-5 d-flex flex-column justify-content-center"
                 style="background: linear-gradient(180deg,#1d2bb8,#3244db);">

                <div class="text-center">

                    <div class="display-1 mb-4">
                        💪
                    </div>

                    <h2 class="fw-bold">
                        Your body can
                        <span class="text-warning">stand</span>
                        almost anything
                    </h2>

                    <p class="mt-4">
                        It's your mind that needs convincing.
                        Push past your limits and transform
                        your body into a powerhouse of strength.
                    </p>

                    <div class="row mt-5">
                        <div class="col-4">
                            <div class="bg-white bg-opacity-10 rounded p-3">
                                <h4>500+</h4>
                                <small>MEMBERS</small>
                            </div>
                        </div>

                        <div class="col-4">
                            <div class="bg-white bg-opacity-10 rounded p-3">
                                <h4>50+</h4>
                                <small>TRAINERS</small>
                            </div>
                        </div>

                        <div class="col-4">
                            <div class="bg-white bg-opacity-10 rounded p-3">
                                <h4>24/7</h4>
                                <small>SUPPORT</small>
                            </div>
                        </div>
                    </div>

                </div>

            </div>

        </div>
    </div>

</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
<script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>

</body>
</html>